		"eslint": "^9.18.0",
		"eslint-config-airbnb": "^19.0.4",
		"eslint-config-airbnb-typescript": "^18.0.0",
		"eslint-config-next": "15.1.5",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-clsx": "^0.0.9",
		"eslint-plugin-import": "^2.29.0",
