{
	"name": "masters-ai",
	"version": "0.1.0",
	"private": true,
	"license": "MIT",
	"scripts": {
		"dev": "vite",
		"dev:all": "bash ./scripts/dev.sh",
		"build": "vite build",
		"preview": "vite preview",
		"start": "vite preview",
		"lint": "eslint components hooks src lib",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:cov": "vitest run --project unit --coverage",
		"tsc": "tsc",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"chromatic": "npx chromatic",
		"wrangler": "wrangler --config worker/wrangler.jsonc",
		"worker:dev": "wrangler dev --config worker/wrangler.jsonc --port 8787",
		"worker:deploy": "wrangler deploy --config worker/wrangler.jsonc --env production",
		"worker:deploy:preview": "wrangler deploy --config worker/wrangler.jsonc --env preview",
		"worker:secrets:preview": "bash ./scripts/sync-worker-secrets.sh preview",
		"worker:secrets:production": "bash ./scripts/sync-worker-secrets.sh production",
		"worker:tsc": "tsc --noEmit -p worker/tsconfig.json",
		"worker:smoke": "ts-node --project worker/tsconfig.scripts.json worker/scripts/smoke.ts",
		"eval": "dotenv -e .dev.vars -e .env -- braintrust eval evals/",
		"eval:rag": "dotenv -e .dev.vars -e .env -- braintrust eval evals/rag-search.eval.ts",
		"eval:name-thread": "dotenv -e .dev.vars -e .env -- braintrust eval evals/name-thread.eval.ts",
		"eval:chat": "dotenv -e .dev.vars -e .env -- braintrust eval evals/chat-agent.eval.ts",
		"eval:chat:openai": "EVAL_CHAT_MODEL=gpt-5.4-mini dotenv -e .dev.vars -e .env -- braintrust eval evals/chat-agent.eval.ts",
		"db:d1:generate": "drizzle-kit generate --config worker/drizzle.config.ts",
		"db:d1:migrate:local": "wrangler d1 migrations apply masters-dev --local --config worker/wrangler.jsonc",
		"db:d1:migrate:dev:remote": "wrangler d1 migrations apply masters-dev --remote --config worker/wrangler.jsonc --env preview",
		"db:d1:migrate:prod:remote": "wrangler d1 migrations apply masters-prod --remote --config worker/wrangler.jsonc --env production",
		"db:courses:backfill:gen": "dotenv -e worker/.dev.vars -- tsx worker/scripts/backfill-courses.ts > \"${TMPDIR:-/tmp}/backfill-courses.sql\"",
		"db:courses:backfill:local": "yarn db:courses:backfill:gen && wrangler d1 execute masters-dev --local --config worker/wrangler.jsonc --file=\"${TMPDIR:-/tmp}/backfill-courses.sql\"",
		"db:courses:backfill:dev:remote": "yarn db:courses:backfill:gen && wrangler d1 execute masters-dev --remote --config worker/wrangler.jsonc --env preview --file=\"${TMPDIR:-/tmp}/backfill-courses.sql\"",
		"db:courses:backfill:prod:remote": "yarn db:courses:backfill:gen && wrangler d1 execute masters-prod --remote --config worker/wrangler.jsonc --env production --file=\"${TMPDIR:-/tmp}/backfill-courses.sql\"",
		"prepare": "husky install"
	},
