# Next.js side (.env). The Worker has its own template at worker/.dev.vars.example.

# Cloudflare Worker URL. http://localhost:8787 in dev; the deployed
# workers.dev / custom domain in prod. Used by the browser to open the
# chat WebSocket and baked into the CSP connect-src directive at build.
NEXT_PUBLIC_WORKER_URL=http://localhost:8787

# Clerk — dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Production Frontend API proxy (CSP script-src/connect-src/frame-src). Dev
# can omit; defaults to https://clerk.femasters.chat at build time.
# NEXT_PUBLIC_CLERK_PROXY_URL=https://clerk.femasters.chat
NEXT_PUBLIC_CLERK_SIGN_UP_URL=http://localhost:3000/auth
NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=http://localhost:3000/chat

# HMAC secret for the anon-id cookie issued by middleware.ts.
# MUST match the worker's ANON_ID_SECRET.
ANON_ID_SECRET=

# Upstash Redis — console.upstash.com
# Used by /api/name-thread (rate limit), /api/user-info (quota readback),
# /api/delete-user (cleanup). Same instance the worker writes to.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Anthropic — console.anthropic.com/settings/keys
# Used by /api/name-thread for thread auto-titling (Haiku 4.5).
ANTHROPIC_API_KEY=

# Optional: enables verbose server logging.
ENABLE_LOGGING=false
