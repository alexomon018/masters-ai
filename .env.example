# Front-end build env (.env). Vite exposes only VITE_-prefixed vars to the
# browser, so everything here is public. Server-only secrets live on the
# Worker (see worker/.dev.vars.example); the SPA has no server runtime.

# Cloudflare Worker URL. http://localhost:8787 in dev; the deployed
# workers.dev / custom domain in prod. Used by the browser to open the
# chat WebSocket and reach the worker's REST surfaces.
VITE_WORKER_URL=http://localhost:8787

# Clerk publishable key — dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=

# Optional: Clerk Frontend API proxy. Dev can omit.
# VITE_CLERK_PROXY_URL=https://clerk.femasters.guru
