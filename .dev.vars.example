# Braintrust eval harness env. Copy to .dev.vars (gitignored) and fill in.
#   cp .dev.vars.example .dev.vars
#
# The eval scripts (yarn eval / eval:rag / eval:name-thread / eval:chat) load
# this file via dotenv-cli, then `braintrust eval` runs the *.eval.ts files.
# These import real production code (ai/llm.ts, worker/src/agent-core.ts,
# worker/src/tools/rag-search.ts), so the harness needs the same provider keys
# the app uses plus a Braintrust key for the dashboard.

# Braintrust — free signup at https://www.braintrust.dev. Each `yarn eval` run
# becomes an experiment, auto-tagged with the current git branch + commit.
BRAINTRUST_API_KEY=

# Anthropic — console.anthropic.com/settings/keys.
# Used by thread naming (Haiku 4.5), the chat-agent eval, and optional LLM judges.
ANTHROPIC_API_KEY=

# OpenAI — platform.openai.com/api-keys.
# Used by the worker for gpt-* chat models (also loaded from .env for local dev).
OPENAI_API_KEY=

# Optional LLM-as-judge scorers (Factuality, TopicSummary):
# EVAL_LLM_JUDGE=1
# EVAL_LLM_JUDGE_PROVIDER=anthropic   # anthropic | openai (default: anthropic)
# EVAL_LLM_JUDGE_MODEL=claude-haiku-4-5

# Upstash Vector — console.upstash.com. The Frontend Masters transcript index.
# Used by the RAG retrieval eval and the chat-agent eval (ragSearch tool).
# Same values as worker/.dev.vars.
UPSTASH_VECTOR_REST_URL=
UPSTASH_VECTOR_REST_TOKEN=
